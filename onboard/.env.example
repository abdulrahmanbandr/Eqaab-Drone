# ─────────────────────────────────────────────────────────────
# Eqaab edge node — example environment. Copy to .env and edit.
#   cp .env.example .env
# Nothing is hardcoded in the code; every operational value is here.
# ─────────────────────────────────────────────────────────────

# Identity / logging (NOT sent on the wire — schemas.py has no drone_id field)
DRONE_ID=eqaab-01
LOG_LEVEL=INFO

# ── GCS WebSocket (REQUIRED) ──────────────────────────────────
GCS_WS_URL=wss://your-gcs-host.example.com/ws/drone
GCS_AUTH_TOKEN=
TELEMETRY_HZ=1.0
RECONNECT_INITIAL_S=1.0
RECONNECT_MAX_S=30.0

# ── Camera (Pi Camera Module 3) ───────────────────────────────
CAMERA_SOURCE=picamera2          # picamera2 | opencv
CAMERA_WIDTH=1280
CAMERA_HEIGHT=720
CAMERA_FPS=30
CAMERA_DEVICE_INDEX=0            # only for CAMERA_SOURCE=opencv
CAMERA_HFLIP=false
CAMERA_VFLIP=false

# ── Detection (unified YOLOv8n: drone=0, person=1, car=2) ──────
MODEL_PATH=models/best_ncnn_model   # NCNN dir (preferred) | best.onnx | best.pt
IMG_SIZE=320                     # 320 (fast) or 416 — never 640
CONF_THRESHOLD=0.45
IOU_THRESHOLD=0.45
DETECT_EVERY_N=3
CLASS_NAMES=drone,person,car

# ── Tracking (DeepSort) ───────────────────────────────────────
TRACK_MAX_AGE=30
TRACK_N_INIT=3
TRACK_MAX_COSINE_DIST=0.2
TRACK_CONFIRM_HITS=3

# ── MAVLink / PX4 (pymavlink) ─────────────────────────────────
MAVLINK_CONNECTION=/dev/ttyACM0  # or /dev/serial0 or udp:127.0.0.1:14540
MAVLINK_BAUD=921600
MAVLINK_HEARTBEAT_TIMEOUT=10.0

# ── Camera geometry (target geo-projection) ───────────────────
CAM_HFOV_DEG=66.0                # Pi Cam Module 3 standard lens (~66). Wide ~ 102
CAM_VFOV_DEG=41.0                # standard ~41. Wide ~ 67
USE_MAVLINK_GIMBAL=true
CAM_MOUNT_PITCH_DOWN_DEG=30.0    # fallback if no gimbal feedback
CAM_MOUNT_YAW_DEG=0.0

# ── IFF policy ────────────────────────────────────────────────
FRIENDLY_DRONE_IDS=EQAAB-01,EQAAB-02
IFF_HOSTILE_MIN_CONF=0.60
